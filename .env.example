# Identra server API used by the mobile auth flow.
# The app accepts either the API root with /v1 or just the server origin.
# iOS simulator/web: http://localhost:4000/v1
# Android emulator: http://10.0.2.2:4000/v1
# Android phone with Expo Go: http://<your-computer-LAN-IP>:4000/v1
# If this is unset in Expo Go, the app tries to infer the LAN IP from Metro.
# Production builds must set this to a real HTTPS API endpoint, not localhost,
# 127.0.0.1, 10.0.2.2, or a LAN testing IP.
EXPO_PUBLIC_IDENTRA_API_URL="http://localhost:4000/v1"
